#!/usr/bin/env bash

set -euo pipefail

current_script_path=${BASH_SOURCE[0]}
plugin_dir=$(dirname "$(dirname "$current_script_path")")

# shellcheck source=./lib/utils.bash
. "${plugin_dir}/lib/utils.bash"

curl_opts=(-sI)

if [ -n "${GITHUB_API_TOKEN:-}" ]; then
	curl_opts=("${curl_opts[@]}" -H "Authorization: token $GITHUB_API_TOKEN")
fi

query=${1:-}
version=

if [ -z "$query" ]; then
	redirect_url=$(curl "${curl_opts[@]}" "$GH_REPO/releases/latest" | sed -n -e "s|^location: *||p" | sed -n -e "s|\r||p")
	if [[ "$redirect_url" != "$GH_REPO/releases" ]]; then
		version="$(printf "%s\n" "$redirect_url" | sed 's|.*/tag/v\{0,1\}||')"
	fi
fi

if [ -z "$version" ]; then
	version="$(list_all_versions | filter_versions "$query" | sort_versions | tail -n1 | xargs echo)"
fi

if [ -z "$version" ]; then
	fail "No versions found${query:+ matching \"$query\"}"
fi

printf "%s\n" "$version"
